<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>PesoLog</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,400;0,500;1,400&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0f0f0f;
  --surface: #181818;
  --surface2: #222;
  --surface3: #2a2a2a;
  --border: #2e2e2e;
  --accent: #e8ff47;
  --accent2: #ff6b35;
  --accent3: #47c9ff;
  --text: #f0f0f0;
  --text-dim: #888;
  --text-muted: #4a4a4a;
  --success: #47ff8a;
  --r: 12px;
  --rs: 8px;
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow-x:hidden;}
body{font-family:'DM Mono',monospace;background:var(--bg);color:var(--text);min-height:100vh;padding-bottom:90px;}

.hdr{background:var(--surface);border-bottom:1px solid var(--border);padding:14px 18px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
.hdr-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:19px;letter-spacing:-1px;}
.hdr-logo span{color:var(--accent);}
.hdr-right{display:flex;align-items:center;gap:10px;}
.hdr-date{font-size:10px;color:var(--text-dim);}
.settings-btn{background:none;border:1px solid var(--border);border-radius:8px;color:var(--text-dim);width:34px;height:34px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.2s;}
.settings-btn:hover{border-color:var(--accent);color:var(--accent);}

.nav{position:fixed;bottom:0;left:0;right:0;background:var(--surface);border-top:1px solid var(--border);display:flex;z-index:50;}
.nb{flex:1;padding:12px 4px;background:none;border:none;color:var(--text-muted);font-family:'DM Mono',monospace;font-size:10px;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:4px;transition:.2s;}
.nb svg{width:20px;height:20px;}
.nb.active{color:var(--accent);}

.page{display:none;padding:16px;}
.page.active{display:block;}

.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:200;align-items:flex-end;justify-content:center;}
.overlay.open{display:flex;}
.overlay-panel{background:var(--surface);border-radius:20px 20px 0 0;width:100%;max-height:90vh;overflow-y:auto;padding:20px;padding-bottom:36px;}
.overlay-handle{width:36px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 18px;}
.overlay-title{font-family:'Syne',sans-serif;font-weight:700;font-size:16px;margin-bottom:18px;}

.pin-dots{display:flex;gap:12px;justify-content:center;margin:20px 0;}
.pin-dot{width:14px;height:14px;border-radius:50%;border:2px solid var(--border);transition:.2s;}
.pin-dot.filled{background:var(--accent);border-color:var(--accent);}
.pin-pad{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:8px;}
.pin-key{background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:16px;font-family:'Syne',sans-serif;font-weight:700;font-size:20px;cursor:pointer;transition:.15s;text-align:center;}
.pin-key:active{background:var(--surface3);transform:scale(.95);}
.pin-key.del{font-size:13px;color:var(--accent2);}
.pin-error{color:var(--accent2);font-size:12px;text-align:center;margin-top:8px;min-height:18px;}

.slabel{font-size:10px;letter-spacing:2px;color:var(--text-muted);text-transform:uppercase;margin-bottom:10px;}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:16px;margin-bottom:14px;}
.card-title{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;color:var(--accent);margin-bottom:14px;}

label{display:block;font-size:11px;color:var(--text-dim);margin-bottom:5px;}
input,select,textarea{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:11px 13px;color:var(--text);font-family:'DM Mono',monospace;font-size:14px;outline:none;transition:border-color .2s;margin-bottom:12px;-webkit-appearance:none;}
input:focus,select:focus,textarea:focus{border-color:var(--accent);}
select option{background:var(--surface2);}
textarea{resize:vertical;min-height:72px;margin-bottom:0;}

.activity-chips{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;}
.chip{background:var(--surface2);border:1px solid var(--border);border-radius:100px;padding:7px 14px;font-size:12px;cursor:pointer;transition:.2s;white-space:nowrap;user-select:none;}
.chip.active{background:var(--accent);border-color:var(--accent);color:#0f0f0f;font-weight:500;}

.mat-row{display:flex;gap:8px;align-items:center;margin-bottom:8px;animation:fadeIn .2s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(-5px);}to{opacity:1;transform:translateY(0);}}
.mat-row input{margin-bottom:0;}
.mat-row .mn{flex:1;}
.mat-row .mp{width:96px;flex-shrink:0;}
.rm-btn{background:none;border:1px solid var(--border);border-radius:6px;color:var(--accent2);width:34px;height:34px;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;font-size:14px;transition:.2s;}
.add-btn{width:100%;background:none;border:1px dashed var(--border);border-radius:var(--rs);color:var(--text-dim);padding:10px;font-family:'DM Mono',monospace;font-size:12px;cursor:pointer;transition:.2s;display:flex;align-items:center;justify-content:center;gap:6px;}
.add-btn:hover{border-color:var(--accent);color:var(--accent);}

.submit-btn{width:100%;background:var(--accent);color:#0f0f0f;border:none;border-radius:var(--r);padding:15px;font-family:'Syne',sans-serif;font-weight:700;font-size:15px;cursor:pointer;transition:.2s;margin-top:6px;}
.submit-btn:active{transform:scale(.98);}

.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;}
.stat{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:14px;}
.stat-l{font-size:10px;color:var(--text-muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;}
.stat-v{font-family:'Syne',sans-serif;font-weight:800;font-size:20px;color:var(--accent);}
.stat-u{font-size:10px;color:var(--text-dim);margin-top:2px;}

.ptabs{display:flex;gap:8px;margin-bottom:14px;}
.ptab{flex:1;background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:8px;color:var(--text-dim);font-family:'DM Mono',monospace;font-size:11px;cursor:pointer;transition:.2s;text-align:center;}
.ptab.active{background:var(--accent);border-color:var(--accent);color:#0f0f0f;font-weight:500;}

.bk-item{display:flex;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);}
.bk-item:last-child{border-bottom:none;}
.bk-name{font-size:12px;min-width:80px;}
.bk-bar-w{flex:1;margin:0 10px;height:3px;background:var(--border);border-radius:2px;}
.bk-bar{height:100%;background:var(--accent);border-radius:2px;transition:width .5s ease;}
.bk-val{font-size:11px;color:var(--accent);min-width:72px;text-align:right;}

.log-entry{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:14px;margin-bottom:10px;}
.log-hdr{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;}
.log-date{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;}
.log-sub{font-size:11px;color:var(--text-dim);margin-top:2px;}
.log-total{font-family:'Syne',sans-serif;font-weight:800;font-size:16px;color:var(--accent);}
.log-tags{display:flex;flex-wrap:wrap;gap:5px;margin-top:8px;}
.tag{background:var(--surface2);border:1px solid var(--border);border-radius:4px;padding:3px 7px;font-size:10px;color:var(--text-dim);}
.tag span{color:var(--text);}
.tag.truck{border-color:#ff6b3540;color:var(--accent2);}
.tag.box{border-color:#47c9ff40;color:var(--accent3);}
.log-note{font-size:11px;color:var(--text-dim);margin-top:8px;padding-top:8px;border-top:1px solid var(--border);font-style:italic;}

.settings-section{margin-bottom:20px;}
.settings-title{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;margin-bottom:10px;color:var(--accent);}
.settings-list{display:flex;flex-direction:column;gap:8px;}
.settings-item{display:flex;align-items:center;justify-content:space-between;background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:10px 12px;}
.settings-item-name{font-size:13px;}
.settings-del{background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:16px;padding:2px 8px;transition:.2s;}
.settings-del:hover{color:var(--accent2);}
.settings-add{display:flex;gap:8px;margin-top:8px;}
.settings-add input{margin-bottom:0;flex:1;}
.settings-add-btn{background:var(--accent);border:none;border-radius:var(--rs);padding:0 14px;color:#0f0f0f;font-family:'Syne',sans-serif;font-weight:700;font-size:13px;cursor:pointer;white-space:nowrap;flex-shrink:0;height:44px;}

.toast{position:fixed;top:70px;left:50%;transform:translateX(-50%) translateY(-10px);background:var(--success);color:#0f0f0f;padding:10px 22px;border-radius:100px;font-family:'Syne',sans-serif;font-weight:700;font-size:13px;opacity:0;transition:all .3s;z-index:999;white-space:nowrap;pointer-events:none;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

.empty{text-align:center;padding:48px 20px;color:var(--text-muted);}
.dropdown-menu{display:none;flex-direction:column;gap:6px;margin-top:8px;animation:fadeIn .2s ease;}
.dropdown-menu.open{display:flex;}
.dropdown-toggle{width:100%;background:none;border:1px solid var(--border);border-radius:var(--rs);padding:10px 14px;color:var(--text-dim);font-family:'DM Mono',monospace;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:8px;transition:.2s;}
.dropdown-toggle:hover{border-color:var(--accent);color:var(--accent);}
.dropdown-toggle .arrow{transition:transform .2s;}
.dropdown-toggle.open .arrow{transform:rotate(180deg);}
@media print{
  body{background:#fff!important;color:#000!important;padding:0!important;}
  .nav,.hdr,.overlay,.page{display:none!important;}
  #printArea{display:block!important;font-family:Arial,sans-serif;padding:20px;}
}
#printArea{display:none;}
.log-actions{display:flex;gap:8px;margin-top:10px;padding-top:10px;border-top:1px solid var(--border);}
.log-act-btn{flex:1;background:none;border:1px solid var(--border);border-radius:var(--rs);padding:8px;font-family:'DM Mono',monospace;font-size:11px;cursor:pointer;transition:.2s;display:flex;align-items:center;justify-content:center;gap:6px;}
.log-act-btn.edit{color:var(--accent3);border-color:#47c9ff30;}
.log-act-btn.edit:hover{background:#081a1f;}
.log-act-btn.del{color:var(--accent2);border-color:#ff6b3530;}
.log-act-btn.del:hover{background:#1a0f08;}
.empty .ico{font-size:36px;margin-bottom:10px;}
.empty p{font-size:12px;line-height:1.7;}

.export-btn{width:100%;background:none;border:1px solid var(--accent2);border-radius:var(--r);padding:11px;font-family:'DM Mono',monospace;font-size:12px;color:var(--accent2);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;margin-top:6px;transition:.2s;}
.export-btn:hover{background:#1a0f08;}
.gdrive-btn{width:100%;background:none;border:1px solid var(--accent3);border-radius:var(--r);padding:11px;font-family:'DM Mono',monospace;font-size:12px;color:var(--accent3);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;margin-top:8px;transition:.2s;}
.gdrive-btn:hover{background:#081a1f;}
.gdrive-btn:disabled{opacity:.4;cursor:not-allowed;}
.gdrive-btn.loading{animation:pulse 1s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.5;}}
.client-id-hint{font-size:10px;color:var(--text-muted);text-align:center;margin-top:6px;line-height:1.5;}

.op-badge{display:inline-flex;align-items:center;gap:6px;background:var(--surface2);border:1px solid var(--border);border-radius:100px;padding:5px 12px;font-size:11px;margin-bottom:14px;}
.op-dot{width:7px;height:7px;border-radius:50%;background:var(--success);}

.sect-divider{height:1px;background:var(--border);margin:14px 0;}
</style>
</head>
<body>

<div class="hdr">
  <div class="hdr-logo">PESO<span>LOG</span></div>
  <div class="hdr-right">
    <div class="hdr-date" id="hdrDate"></div>
    <button class="settings-btn" onclick="openPin()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
    </button>
  </div>
</div>

<div id="toastEl" class="toast"></div>

<!-- PIN OVERLAY -->
<div class="overlay" id="pinOverlay">
  <div class="overlay-panel">
    <div class="overlay-handle"></div>
    <div class="overlay-title">🔒 Accesso Impostazioni</div>
    <div class="pin-dots" id="pinDots">
      <div class="pin-dot" id="pd0"></div><div class="pin-dot" id="pd1"></div>
      <div class="pin-dot" id="pd2"></div><div class="pin-dot" id="pd3"></div>
    </div>
    <div class="pin-error" id="pinError"></div>
    <div class="pin-pad">
      <button class="pin-key" onclick="pinPress('1')">1</button>
      <button class="pin-key" onclick="pinPress('2')">2</button>
      <button class="pin-key" onclick="pinPress('3')">3</button>
      <button class="pin-key" onclick="pinPress('4')">4</button>
      <button class="pin-key" onclick="pinPress('5')">5</button>
      <button class="pin-key" onclick="pinPress('6')">6</button>
      <button class="pin-key" onclick="pinPress('7')">7</button>
      <button class="pin-key" onclick="pinPress('8')">8</button>
      <button class="pin-key" onclick="pinPress('9')">9</button>
      <button class="pin-key" onclick="closeOverlay('pinOverlay')">✕</button>
      <button class="pin-key" onclick="pinPress('0')">0</button>
      <button class="pin-key del" onclick="pinDel()">⌫ DEL</button>
    </div>
  </div>
</div>

<!-- SETTINGS OVERLAY -->
<div class="overlay" id="settingsOverlay">
  <div class="overlay-panel">
    <div class="overlay-handle"></div>
    <div class="overlay-title">⚙️ Impostazioni</div>

    <div class="settings-section">
      <div class="settings-title">Operatori</div>
      <div class="settings-list" id="settingsOperatori"></div>
      <div class="settings-add">
        <input type="text" id="newOperatore" placeholder="Nome operatore">
        <button class="settings-add-btn" onclick="addSetting('operatori','newOperatore','Operatori')">+</button>
      </div>
    </div>

    <div class="settings-section">
      <div class="settings-title">Tipi di materiale</div>
      <div class="settings-list" id="settingsMateriali"></div>
      <div class="settings-add">
        <input type="text" id="newMateriale" placeholder="Es. Acciaio">
        <button class="settings-add-btn" onclick="addSetting('materiali','newMateriale','Materiali')">+</button>
      </div>
    </div>

    <div class="settings-section">
      <div class="settings-title">Box ammendante</div>
      <div class="settings-list" id="settingsBox"></div>
      <div class="settings-add">
        <input type="text" id="newBox" placeholder="Es. Box A">
        <button class="settings-add-btn" onclick="addSetting('box','newBox','Box')">+</button>
      </div>
    </div>

    <div class="settings-section">
      <div class="settings-title">Luoghi (Da / A)</div>
      <div class="settings-list" id="settingsLuoghi"></div>
      <div class="settings-add">
        <input type="text" id="newLuogo" placeholder="Es. Magazzino">
        <button class="settings-add-btn" onclick="addSetting('luoghi','newLuogo','Luoghi')">+</button>
      </div>
    </div>

    <div class="settings-section">
      <div class="settings-title">Destinatari email settimanale</div>
      <div style="font-size:11px;color:var(--text-dim);line-height:1.7;margin-bottom:10px;">
        Inserisci uno o più indirizzi email separati da virgola. Riceveranno il riepilogo settimanale ogni martedì mattina.
      </div>
      <div class="settings-list" id="settingsEmail"></div>
      <div class="settings-add">
        <input type="email" id="newEmail" placeholder="es. nome@azienda.it">
        <button class="settings-add-btn" onclick="addEmail()">+</button>
      </div>
    </div>

    <div class="settings-section">
      <div class="settings-title">Cambia PIN</div>
      <div style="display:flex;gap:8px;">
        <input type="password" id="newPin" placeholder="Nuovo PIN (4 cifre)" maxlength="4" style="margin-bottom:0;">
        <button class="settings-add-btn" onclick="changePin()">Salva</button>
      </div>
    </div>

    <div class="settings-section">
      <div class="settings-title">Nome dispositivo</div>
      <div style="font-size:11px;color:var(--text-dim);line-height:1.7;margin-bottom:10px;">
        Imposta un nome diverso su ogni dispositivo (es. <strong>pc</strong> sul PC, <strong>tablet</strong> sul tablet). Il file su Drive verrà salvato come <strong>pesolog_dati_[nome].json</strong>.
      </div>
      <div style="display:flex;gap:8px;">
        <input type="text" id="dispositvoInput" placeholder="es. pc oppure tablet" style="margin-bottom:0;">
        <button class="settings-add-btn" onclick="saveDispositivo()">Salva</button>
      </div>
      <div id="dispositivoStatus" style="font-size:11px;color:var(--text-muted);margin-top:6px;"></div>
    </div>

    <div class="settings-section">
      <div class="settings-title">Google Drive — Script URL</div>
      <div style="font-size:11px;color:var(--text-dim);line-height:1.7;margin-bottom:10px;">
        Inserisci l'URL del tuo Google Apps Script. I dati vengono salvati automaticamente ad ogni report in un file unico <strong>pesolog_dati.json</strong> nella cartella PesoLog.
      </div>
      <div style="display:flex;gap:8px;">
        <input type="text" id="scriptUrlInput" placeholder="https://script.google.com/macros/s/..." style="margin-bottom:0;font-size:11px;">
        <button class="settings-add-btn" onclick="saveScriptUrl()">Salva</button>
      </div>
      <div id="clientIdStatus" style="font-size:11px;color:var(--text-muted);margin-top:6px;"></div>
    </div>

    <div class="settings-section">
      <div class="settings-title">Esporta file configurato</div>
      <div style="font-size:11px;color:var(--text-dim);line-height:1.7;margin-bottom:10px;">
        Scarica una copia del file con operatori, materiali, box e PIN già salvati dentro. Condividila con i colleghi: la apriranno già pronta all'uso.
      </div>
      <button class="export-btn" style="margin-top:0;" onclick="exportConfiguredFile()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Scarica file configurato (.html)
      </button>
    </div>

    <div class="settings-section">
      <div class="settings-title">Backup impostazioni</div>
      <div style="font-size:11px;color:var(--text-dim);line-height:1.7;margin-bottom:10px;">
        Esporta le impostazioni in un file da conservare. In caso di cancellazione cache, importale per ripristinare tutto.
      </div>
      <div style="display:flex;gap:8px;">
        <button class="settings-add-btn" onclick="esportaImpostazioni()" style="flex:1;height:44px;font-size:12px;">⬇ Esporta impostazioni</button>
        <button class="settings-add-btn" onclick="importaImpostazioni()" style="flex:1;height:44px;font-size:12px;background:none;border:1px solid var(--accent);color:var(--accent);">⬆ Importa impostazioni</button>
      </div>
    </div>

    <button class="submit-btn" onclick="closeOverlay('settingsOverlay')">Chiudi</button>
  </div>
</div>

<!-- PAGE: INSERIMENTO -->
<div id="page-inserimento" class="page active">
  <div class="op-badge"><div class="op-dot"></div><span id="badgeOp">— seleziona operatore —</span></div>
  <div class="slabel">Nuovo Report</div>

  <div class="card">
    <div class="card-title">Dati generali</div>
    <label>Data</label>
    <input type="date" id="dataInput">
    <label>Operatore</label>
    <select id="operatoreInput" onchange="document.getElementById('badgeOp').textContent=this.value||'— seleziona operatore —'">
      <option value="">Seleziona...</option>
    </select>
    <label>Turno</label>
    <select id="turnoInput">
      <option>Mattina</option><option>Pomeriggio</option><option>Notte</option>
    </select>
  </div>

  <div class="card">
    <div class="card-title">Attività del giorno</div>
    <div style="font-size:11px;color:var(--text-dim);margin-bottom:10px;">Seleziona una o più attività svolte:</div>
    <div class="activity-chips" id="activityChips">
