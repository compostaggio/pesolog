<script>
// ── DATA ──────────────────────────────────────────────────────────────────
let reports = JSON.parse(localStorage.getItem('pl_reports') || '[]').map(r=>({...r, materiali: r.materiali||[]}));
let conferimenti = JSON.parse(localStorage.getItem('pl_conferimenti') || '[]');
function saveConferimenti(){ localStorage.setItem('pl_conferimenti', JSON.stringify(conferimenti)); }
let depIniziale = JSON.parse(localStorage.getItem('pl_dep_iniziale') || 'null') || { data:'', sovvallo:0, inoculo:0, organico:0 };
function saveDepIniziale_(){ localStorage.setItem('pl_dep_iniziale', JSON.stringify(depIniziale)); }
let settings = JSON.parse(localStorage.getItem('pl_settings') || 'null') || {
  operatori: ['Mario Rossi','Luigi Bianchi','Anna Verdi','Marco Esposito'],
  materiali: ['Acciaio','Alluminio','Rame','Ghisa','Plastica','Cartone','Legno'],
  box: ['Box A','Box B','Box C','Box D'],
  luoghi: ['Magazzino','Area A','Area B','Capannone','Esterno','Banchina'],
  emails: [],
  dispositivo: 'pc',
  pin: '1234'
};
function saveData(){ localStorage.setItem('pl_reports', JSON.stringify(reports)); }
function saveSettings(){ localStorage.setItem('pl_settings', JSON.stringify(settings)); }

// Migrazione: aggiunge chiavi mancanti se settings salvato è vecchio
if(!settings.luoghi){ settings.luoghi = ['Magazzino','Area A','Area B','Capannone','Esterno','Banchina']; saveSettings(); }
if(!settings.emails){ settings.emails = []; saveSettings(); }
if(!settings.dispositivo){ settings.dispositivo = 'pc'; saveSettings(); }

// ── INIT ──────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  const d = new Date();
  document.getElementById('hdrDate').textContent =
    d.toLocaleDateString('it-IT',{weekday:'short',day:'numeric',month:'short'}).toUpperCase();
  document.getElementById('dataInput').value = d.toISOString().split('T')[0];
  populateSelects();
  addMaterial();
  // Default: mese corrente
  const _now = new Date();
  const _firstDay = _now.toISOString().slice(0,7) + '-01';
  const _lastDay = new Date(_now.getFullYear(), _now.getMonth()+1, 0).toISOString().split('T')[0];
  document.getElementById('filterDa').value = _firstDay;
  document.getElementById('filterA').value = _lastDay;
  renderRiepilogo();
  renderStorico();
  // Default depositi: inizio anno corrente
  const _depStart = new Date().getFullYear() + '-01-01';
  const _depEnd = new Date().toISOString().split('T')[0];
  if(document.getElementById('depDa')) document.getElementById('depDa').value = _depStart;
  if(document.getElementById('depA')) document.getElementById('depA').value = _depEnd;
  // Default conferimento: settimana corrente (lun-dom)
  const _now2 = new Date();
  const _mon = new Date(_now2); _mon.setDate(_now2.getDate()-(_now2.getDay()+6)%7);
  const _sun = new Date(_mon); _sun.setDate(_mon.getDate()+6);
  if(document.getElementById('confDal')) document.getElementById('confDal').value = _mon.toISOString().split('T')[0];
  if(document.getElementById('confAl'))  document.getElementById('confAl').value  = _sun.toISOString().split('T')[0];

  // Default previsione: ultime 8 settimane per lavorato, ultimi 2 mesi per conferito
  const _prevNow = new Date();
  const _prev8w = new Date(_prevNow); _prev8w.setDate(_prevNow.getDate()-56);
  const _prev2m = new Date(_prevNow); _prev2m.setMonth(_prevNow.getMonth()-2);
  if(document.getElementById('prevLavDal'))  document.getElementById('prevLavDal').value  = _prev8w.toISOString().split('T')[0];
  if(document.getElementById('prevLavAl'))   document.getElementById('prevLavAl').value   = _prevNow.toISOString().split('T')[0];
  if(document.getElementById('prevConfDal')) document.getElementById('prevConfDal').value = _prev2m.toISOString().split('T')[0];
  if(document.getElementById('prevConfAl'))  document.getElementById('prevConfAl').value  = _prevNow.toISOString().split('T')[0];

  // Default grafici: ultimi 3 mesi
  const _g3 = new Date(); _g3.setMonth(_g3.getMonth()-3);
  document.getElementById('grafDa').value = _g3.toISOString().split('T')[0];
  document.getElementById('grafA').value = new Date().toISOString().split('T')[0];
});

function populateSelects(){
  const op = document.getElementById('operatoreInput');
  const cur = op.value;
  op.innerHTML = '<option value="">Seleziona...</option>';
  settings.operatori.forEach(o => { const e=document.createElement('option'); e.value=e.textContent=o; op.appendChild(e); });
  if(cur) op.value = cur;

  const bx = document.getElementById('boxInput');
  const curB = bx.value;
  bx.innerHTML = '<option value="">Seleziona box...</option>';
  settings.box.forEach(b => { const e=document.createElement('option'); e.value=e.textContent=b; bx.appendChild(e); });
  if(curB) bx.value = curB;
}

// ── NAVIGATION ────────────────────────────────────────────────────────────
function showPage(name, btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nb').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  btn.classList.add('active');
  if(name==='riepilogo') renderRiepilogo();
  if(name==='storico') renderStorico();
  if(name==='grafici') renderGrafici();
  if(name==='depositi') renderDepositi();
  if(name==='scenari'){ renderPrevisione(); renderObiettivoSuggestion(); renderSimulatore(); initMultiFase(); renderMultiFase(); }
}

// ── CHIPS ─────────────────────────────────────────────────────────────────
const activeSects = new Set(['materiali']);
function toggleChip(chip){
  const t = chip.dataset.type;
  if(activeSects.has(t)){
    if(activeSects.size===1) return;
    activeSects.delete(t); chip.classList.remove('active');
  } else {
    activeSects.add(t); chip.classList.add('active');
  }
  document.getElementById('sect-materiali').style.display = activeSects.has('materiali') ? '' : 'none';
  document.getElementById('sect-camion').style.display    = activeSects.has('camion')    ? '' : 'none';
  document.getElementById('sect-ammendante').style.display= activeSects.has('ammendante')? '' : 'none';
}

// ── MATERIAL ROWS ─────────────────────────────────────────────────────────
let matCnt = 0;
function addMaterial(){
  matCnt++;
  const id = 'mr'+matCnt;
  if(!document.getElementById('dl_mat')){
    const dl=document.createElement('datalist'); dl.id='dl_mat';
    settings.materiali.forEach(m=>{ const o=document.createElement('option'); o.value=m; dl.appendChild(o); });
    document.body.appendChild(dl);
  }
  if(!document.getElementById('dl_luoghi')){
    const dl=document.createElement('datalist'); dl.id='dl_luoghi';
    settings.luoghi.forEach(l=>{ const o=document.createElement('option'); o.value=l; dl.appendChild(o); });
    document.body.appendChild(dl);
  }
  const div=document.createElement('div');
  div.className='mat-row'; div.id=id;
  div.style.cssText='display:grid;grid-template-columns:2fr 1fr 1fr 1fr 34px;gap:6px;align-items:center;margin-bottom:8px;';
  div.innerHTML=`
    <input type="text" class="mn" placeholder="Materiale" list="dl_mat" style="margin-bottom:0;">
    <input type="number" class="mp" placeholder="kg" min="0" step="0.1" style="margin-bottom:0;">
    <input type="text" class="mda" placeholder="Da" list="dl_luoghi" style="margin-bottom:0;">
    <input type="text" class="ma" placeholder="A" list="dl_luoghi" style="margin-bottom:0;">
    <button class="rm-btn" onclick="removeMat('${id}')">✕</button>`;
  document.getElementById('materialList').appendChild(div);
}
function removeMat(id){
  const el=document.getElementById(id);
  if(el && document.querySelectorAll('.mat-row').length>1) el.remove();
}

// ── CAMION ROWS ───────────────────────────────────────────────────────────
let camCnt = 0;
function addCamionRow(){
  camCnt++;
  const id = 'cr'+camCnt;
  const div=document.createElement('div');
  div.className='mat-row'; div.id=id;
  div.style.cssText='display:grid;grid-template-columns:2fr 1fr 1fr 34px;gap:6px;align-items:center;margin-bottom:8px;';
  div.innerHTML=`<input type="text" class="cn" placeholder="Tipo carico" list="dl_mat" style="margin-bottom:0;"><input type="number" class="cp" placeholder="kg" min="0" step="0.1" style="margin-bottom:0;"><input type="number" class="cc" placeholder="n° cam" min="0" style="margin-bottom:0;text-align:center;"><button class="rm-btn" onclick="removeCamionRow('${id}')">✕</button>`;
  document.getElementById('camionList').appendChild(div);
}
function removeCamionRow(id){
  const el=document.getElementById(id);
  if(el && document.querySelectorAll('#camionList .mat-row').length>1) el.remove();
}

// ── SAVE ──────────────────────────────────────────────────────────────────
function salvaReport(){
  const data=document.getElementById('dataInput').value;
  const operatore=document.getElementById('operatoreInput').value;
  const turno=document.getElementById('turnoInput').value;
  const note=document.getElementById('noteInput').value.trim();
  if(!data||!operatore){ showToast('⚠ Inserisci data e operatore','#ff6b35'); return; }

  // Legge sempre tutti i campi, indipendentemente dai chip visibili
  let materiali=[];
  document.querySelectorAll('#materialList .mat-row').forEach(r=>{
    const n=r.querySelector('.mn').value.trim();
    const p=parseFloat(r.querySelector('.mp').value)||0;
    const da=r.querySelector('.mda').value.trim();
    const a=r.querySelector('.ma').value.trim();
    if(n&&p>0) materiali.push({nome:n,peso:p,da,a});
  });

  let camion=null;
  const carichiList=[];
  document.querySelectorAll('#camionList .mat-row').forEach(r=>{
    const n=r.querySelector('.cn').value.trim();
    const p=parseFloat(r.querySelector('.cp').value)||0;
    const c=parseInt(r.querySelector('.cc').value)||0;
    if(n) carichiList.push({nome:n,peso:p,numCamion:c});
  });
  if(carichiList.length) camion={carichi:carichiList};

  let ammendante=null;
  const box=document.getElementById('boxInput').value;
  const ammQta=parseFloat(document.getElementById('ammQtaInput').value)||0;
  const ammDa=document.getElementById('ammDaInput').value.trim();
  if(box) ammendante={box,qta:ammQta,da:ammDa};

  if(materiali.length===0 && camion===null && ammendante===null){
    showToast('⚠ Nessun dato da salvare','#ff6b35'); return;
  }

  const totCarichi=(camion?.carichi||[]).reduce((s,c)=>s+c.peso,0);
  const totale=materiali.reduce((s,m)=>s+m.peso,0)+totCarichi+(ammendante?.qta||0);
  reports.push({id:Date.now(),data,operatore,turno,materiali,camion,ammendante,totale,note,ts:new Date().toISOString()});
  saveData();
  syncToDrive(true);
  showToast('✓ Report salvato!','var(--success)');
  if(settings.emails.length) syncEmailConfig();
  resetForm();
}

function resetForm(){
  const today=new Date().toISOString().split('T')[0];
  document.getElementById('dataInput').value=today;
  document.getElementById('operatoreInput').value='';
  document.getElementById('turnoInput').value='Mattina';
  document.getElementById('noteInput').value='';
  document.getElementById('camionList').innerHTML=''; camCnt=0;
  document.getElementById('ammQtaInput').value='';
  document.getElementById('ammDaInput').value='';
  document.getElementById('boxInput').value='';
  document.getElementById('materialList').innerHTML='';
  document.getElementById('badgeOp').textContent='— seleziona operatore —';
  activeSects.clear(); activeSects.add('materiali');
  document.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));
  document.querySelector('[data-type="materiali"]').classList.add('active');
  document.getElementById('sect-materiali').style.display='';
  document.getElementById('sect-camion').style.display='none';
  document.getElementById('sect-ammendante').style.display='none';
  addMaterial();
}

// ── TOAST ─────────────────────────────────────────────────────────────────
function showToast(msg, color){
  const t=document.getElementById('toastEl');
  t.textContent=msg;
  t.style.background=(color&&color!=='var(--success)')?color:'var(--success)';
  t.style.color=(color&&color!=='var(--success)')? '#fff':'#0f0f0f';
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2400);
}

// ── RIEPILOGO ─────────────────────────────────────────────────────────────
function setQuick(period, btn){
  const now = new Date();
  const today = now.toISOString().split('T')[0];
  let da, a;
  if(period==='oggi'){
    da = today; a = today;
  } else if(period==='settimana'){
    const w = new Date(now); w.setDate(now.getDate()-6);
    da = w.toISOString().split('T')[0]; a = today;
  } else if(period==='mese'){
    da = today.slice(0,7) + '-01';
    const lastDay = new Date(now.getFullYear(), now.getMonth()+1, 0);
    a = lastDay.toISOString().split('T')[0];
  } else {
    da = ''; a = '';
  }
  document.getElementById('filterDa').value = da;
  document.getElementById('filterA').value = a;
  document.querySelectorAll('.ptab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderRiepilogo();
}

function getFiltered(){
  const da = document.getElementById('filterDa')?.value || '';
  const a  = document.getElementById('filterA')?.value  || '';
  return reports.filter(r=>{
    if(da && r.data < da) return false;
    if(a  && r.data > a)  return false;
    return true;
  });
}
function renderRiepilogo(){
  const f=getFiltered();
  const totPeso=f.reduce((s,r)=>s+r.totale,0);
  const totCamion=f.reduce((s,r)=>s+(r.camion?.carichi||[]).reduce((a,c)=>a+(c.numCamion||0),0),0);
  const totAmm=f.reduce((s,r)=>s+(r.ammendante?.qta||0),0);
  document.getElementById('stTotale').textContent=fmtK(totPeso);
  document.getElementById('stReport').textContent=f.length;
  document.getElementById('stCamion').textContent=totCamion;
  document.getElementById('stAmm').textContent=fmtK(totAmm);

  // Materiali breakdown
  const matMap={};
  f.forEach(r=>(r.materiali||[]).forEach(m=>{
    const nl = m.nome.toLowerCase();
    const da = (m.da||'').trim();
    const a  = (m.a||'').trim();
    const daL = da.toLowerCase();
    const aL  = a.toLowerCase();

    if(nl.includes('sovvallo')){
      const key = daL.includes('50x50') ? m.nome+' (In fossa)' : m.nome+' (prodotto)';
      matMap[key]=(matMap[key]||0)+m.peso;

    } else if(nl.includes('inoculo')){
      // Inoculo riutilizzato: inserito a mano con campo A compilato
      if(a) { const k=m.nome+' (riutilizzato)'; matMap[k]=(matMap[k]||0)+m.peso; }
      // Inoculo prodotto calcolato dopo (Vagliatura - Sovvallo prodotto)

    } else if(nl.includes('organico')){
      // Organico: conta nel totale solo se Da è vuoto (esclude trasferimenti)
      if(!da) matMap[m.nome]=(matMap[m.nome]||0)+m.peso;
      // Sottovoci aggiuntive
      if(aL.includes('dige'))                    { const k=m.nome+' → Digestore';    matMap[k]=(matMap[k]||0)+m.peso; }
      if(aL.includes('biocella') && !da)         { const k=m.nome+' → Compostaggio'; matMap[k]=(matMap[k]||0)+m.peso; }

    } else {
      matMap[m.nome]=(matMap[m.nome]||0)+m.peso;
    }
  }));
  // Inoculo (prodotto) = Vagliatura - Sovvallo (prodotto)
  {
    let totVagliatura = 0, totSovvalloProdotto = 0;
    let nomeInoculo = 'Inoculo';
    f.forEach(r=>(r.materiali||[]).forEach(m=>{
      const nl = m.nome.toLowerCase();
      if(nl.includes('vagliatura')) totVagliatura += (m.peso||0);
      if(nl.includes('sovvallo') && !(m.da||'').toLowerCase().includes('50x50')) totSovvalloProdotto += (m.peso||0);
      if(nl.includes('inoculo')) nomeInoculo = m.nome;
    }));
    const inoculoProdotto = Math.max(0, totVagliatura - totSovvalloProdotto);
    if(inoculoProdotto > 0) matMap[nomeInoculo+' (prodotto)'] = inoculoProdotto;
  }
  const sorted=Object.entries(matMap).sort((a,b)=>b[1]-a[1]);
  const maxV=sorted.length?sorted[0][1]:1;
  const bl=document.getElementById('breakdownList');
  if(!sorted.length){ bl.innerHTML='<div style="color:var(--text-muted);font-size:12px;padding:10px 0">Nessun dato nel periodo.</div>'; }
  else { bl.innerHTML=sorted.map(([n,v])=>{
    const isSpostato = n.includes('(In fossa)');
    const isProdotto = n.includes('(prodotto)');
    const isDigest  = n.includes('→ Digestore');
    const isCompost = n.includes('→ Compostaggio');
    const isInFossa = n.includes('(In fossa)');
    const isInoculoProd = n.includes('(prodotto)') && n.toLowerCase().includes('inoculo');
    const isInoculoRiut = n.includes('(riutilizzato)');
    const barColor = isInFossa ? 'var(--accent3)' : isDigest ? '#b47fff' : isCompost ? '#47ffb0' : isInoculoProd ? '#ffb347' : isInoculoRiut ? '#ff8c69' : 'var(--accent)';
    const valColor = isInFossa ? 'var(--accent3)' : isDigest ? '#b47fff' : isCompost ? '#47ffb0' : isInoculoProd ? '#ffb347' : isInoculoRiut ? '#ff8c69' : 'var(--accent)';
    return `<div class="bk-item"><span class="bk-name">${n}</span><div class="bk-bar-w"><div class="bk-bar" style="width:${(v/maxV*100).toFixed(1)}%;background:${barColor}"></div></div><span class="bk-val" style="color:${valColor}">${fmtPeso(v)}</span></div>`;
  }).join(''); }

  // Camion breakdown
  const camMap={};
  f.forEach(r=>(r.camion?.carichi||[]).forEach(c=>{ if(c.nome) camMap[c.nome]=(camMap[c.nome]||{kg:0,n:0}); camMap[c.nome].kg+=(c.peso||0); camMap[c.nome].n+=(c.numCamion||0); }));
  const sortedCam=Object.entries(camMap).sort((a,b)=>b[1].kg-a[1].kg);
  const maxCam=sortedCam.length?sortedCam[0][1].kg:1;
  const bc=document.getElementById('breakdownCamion');
  if(!sortedCam.length){ bc.innerHTML='<div style="color:var(--text-muted);font-size:12px;padding:10px 0">Nessun carico camion nel periodo.</div>'; }
  else { bc.innerHTML=sortedCam.map(([n,v])=>`<div class="bk-item"><span class="bk-name">${n}</span><div class="bk-bar-w"><div class="bk-bar" style="width:${(v.kg/maxCam*100).toFixed(1)}%;background:var(--accent2)"></div></div><span class="bk-val" style="color:var(--accent2)">${fmtPeso(v.kg)} · ${v.n} cam</span></div>`).join(''); }
}

// ── STORICO ───────────────────────────────────────────────────────────────
function renderStorico(){
  const c=document.getElementById('storicoList');
  if(!reports.length){ c.innerHTML='<div class="empty"><div class="ico">📋</div><p>Nessun report ancora.<br>Inserisci il primo report giornaliero.</p></div>'; return; }
  const sorted=[...reports].sort((a,b)=>new Date(b.data)-new Date(a.data));
  c.innerHTML=sorted.map(r=>`
    <div class="log-entry">
      <div class="log-hdr">
        <div>
          <div class="log-date">${fmtData(r.data)} — ${r.turno}</div>
          <div class="log-sub">${r.operatore}</div>
        </div>
        <div class="log-total">${fmtPeso(r.totale)}</div>
      </div>
      <div class="log-tags">
        ${(r.materiali||[]).map(m=>`<div class="tag">${m.nome} <span>${fmtPeso(m.peso)}${m.da||m.a?' · '+[m.da,m.a].filter(Boolean).join('→'):''}</span></div>`).join('')}
        ${r.camion?.carichi?.map(c=>`<div class="tag truck">🚛 ${c.nome} <span>${c.peso?fmtPeso(c.peso):''} ${c.numCamion?'· '+c.numCamion+' cam':''}</span></div>`).join('')||''}
        ${r.ammendante?`<div class="tag box">🌱 <span>${r.ammendante.da?r.ammendante.da+' → ':''} ${r.ammendante.box} — ${fmtPeso(r.ammendante.qta)}</span></div>`:''}
      </div>
      ${r.note?`<div class="log-note">${r.note}</div>`:''}
      <div class="log-actions">
        <button class="log-act-btn edit" onclick="openEdit('${r.id}')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Modifica
        </button>
        <button class="log-act-btn del" onclick="deleteReport('${r.id}')">
