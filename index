// Carica Chart.js dinamicamente
(function(){
  const s=document.createElement('script');
  s.src='https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js';
  s.onload=()=>{ if(document.getElementById('page-grafici').classList.contains('active')) renderGrafici(); };
  document.head.appendChild(s);
})();

let chartPesi=null, chartMensile=null, chartAmm=null;

function setGrafPeriod(period, btn){
  const now = new Date();
  const today = now.toISOString().split('T')[0];
  let da;
  if(period==='mese'){ da=today.slice(0,7)+'-01'; }
  else if(period==='3mesi'){ const d=new Date(now); d.setMonth(d.getMonth()-3); da=d.toISOString().split('T')[0]; }
  else if(period==='anno'){ da=now.getFullYear()+'-01-01'; }
  else { da=''; }
  document.getElementById('grafDa').value=da;
  document.getElementById('grafA').value=today;
  document.querySelectorAll('#page-grafici .ptab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderGrafici();
}

function getGrafFiltered(){
  const da=document.getElementById('grafDa')?.value||'';
  const a=document.getElementById('grafA')?.value||'';
  return reports.filter(r=>{
    if(da&&r.data<da) return false;
    if(a&&r.data>a) return false;
    return true;
  });
}

function getWeekKey(dateStr){
  const d=new Date(dateStr+'T12:00:00');
  const mon=new Date(d); mon.setDate(d.getDate()-((d.getDay()+6)%7));
  return mon.toISOString().split('T')[0];
}

function renderGrafici(){
  if(typeof Chart==='undefined') return;
  const f=getGrafFiltered();
  if(!f.length) return;

  // ── Aggregazione settimanale ──
  const weekMap={};
  f.forEach(r=>{
    const wk=getWeekKey(r.data);
    if(!weekMap[wk]) weekMap[wk]={peso:0,amm:0,mat:{}};
    weekMap[wk].peso+=r.totale;
    weekMap[wk].amm+=(r.ammendante?.qta||0);
    r.materiali.forEach(m=>{
      weekMap[wk].mat[m.nome]=(weekMap[wk].mat[m.nome]||0)+m.peso;
    });
  });
  const weeks=Object.keys(weekMap).sort();

  // Etichetta: "10/03 - 16/03"
  const labelWeeks=weeks.map(w=>{
    const mon=new Date(w+'T12:00:00');
    const sun=new Date(mon); sun.setDate(mon.getDate()+6);
    const fmt=d=>d.toLocaleDateString('it-IT',{day:'2-digit',month:'2-digit'});
    return fmt(mon)+' - '+fmt(sun);
  });

  // Top 5 materiali per quantità totale nel periodo
  const matTot={};
  f.forEach(r=>(r.materiali||[]).forEach(m=>{ matTot[m.nome]=(matTot[m.nome]||0)+m.peso; }));
  const top5=Object.entries(matTot).sort((a,b)=>b[1]-a[1]).slice(0,5).map(x=>x[0]);
  const palette=['#e8ff47','#47c9ff','#ff6b35','#47ff8a','#b47fff'];

  const gridColor='rgba(255,255,255,0.08)';
  const textColor='#888';
  const tooltipKg=(ctx)=>ctx.parsed.y.toLocaleString('it-IT')+' kg';
  const baseOpts={
    responsive:true,
    plugins:{
      legend:{labels:{color:textColor,font:{size:11}}},
      tooltip:{callbacks:{label:ctx=>ctx.dataset.label+': '+ctx.parsed.y.toLocaleString('it-IT')+' kg'}}
    },
    scales:{
      x:{ticks:{color:textColor,font:{size:10},maxRotation:45},grid:{color:gridColor}},
      y:{ticks:{color:textColor,font:{size:10},callback:v=>v>=1000?(v/1000).toFixed(1)+'t':v+' kg'},grid:{color:gridColor}}
    }
  };

  // CHART 1 — Andamento pesi settimanali (linea)
  if(chartPesi) chartPesi.destroy();
  chartPesi=new Chart(document.getElementById('chartPesi'),{
    type:'line',
    data:{
      labels:labelWeeks,
      datasets:[{
        label:'Peso totale',
        data:weeks.map(w=>Math.round(weekMap[w].peso)),
        borderColor:'#e8ff47',backgroundColor:'rgba(232,255,71,0.08)',
        tension:0.3,pointBackgroundColor:'#e8ff47',pointRadius:5,pointHoverRadius:7,fill:true
      }]
    },
    options:baseOpts
  });

  // CHART 2 — Confronto settimanale per materiale (barre raggruppate)
  if(chartMensile) chartMensile.destroy();
  chartMensile=new Chart(document.getElementById('chartMensile'),{
    type:'bar',
    data:{
      labels:labelWeeks,
      datasets:top5.map((mat,i)=>({
        label:mat,
        data:weeks.map(w=>Math.round(weekMap[w].mat[mat]||0)),
        backgroundColor:palette[i]+'bb',
        borderColor:palette[i],
        borderWidth:1
      }))
    },
    options:{...baseOpts}
  });

  // CHART 3 — Ammendante settimanale (barre)
  if(chartAmm) chartAmm.destroy();
  chartAmm=new Chart(document.getElementById('chartAmm'),{
    type:'bar',
    data:{
      labels:labelWeeks,
      datasets:[{
        label:'Ammendante prodotto',
        data:weeks.map(w=>Math.round(weekMap[w].amm)),
        backgroundColor:'rgba(71,255,138,0.65)',
        borderColor:'#47ff8a',borderWidth:1
      }]
    },
    options:baseOpts
  });
}

