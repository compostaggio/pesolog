  if(mfFasi.length <= 1) return;
  mfFasi.splice(i, 1);
  renderFasiInput();
  renderMultiFase();
}

function renderFasiInput(){
  const container = document.getElementById('mfFasiContainer');
  if(!container) return;
  container.innerHTML = mfFasi.map((f, i) => `
    <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:12px;margin-bottom:8px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
        <div style="font-size:12px;font-weight:600;color:var(--accent);">Fase ${i+1}</div>
        ${mfFasi.length>1 ? `<button onclick="rimuoviFase(${i})" style="background:none;border:none;color:var(--accent2);cursor:pointer;font-size:13px;">✕ Rimuovi</button>` : ''}
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;">
        <div>
          <label>Durata (settimane)</label>
          <input type="number" value="${f.settimane}" min="1" oninput="mfFasi[${i}].settimane=parseInt(this.value)||1;renderMultiFase()" style="margin-bottom:0;">
        </div>
        <div>
          <label>Organico ingresso (t/sett)</label>
          <input type="number" value="${f.ingresso}" placeholder="es. 1200" min="0" step="0.1" oninput="mfFasi[${i}].ingresso=this.value;renderMultiFase()" style="margin-bottom:0;">
        </div>
        <div>
          <label>Organico uscita (t/sett)</label>
          <input type="number" value="${f.uscita}" placeholder="es. 1100" min="0" step="0.1" oninput="mfFasi[${i}].uscita=this.value;renderMultiFase()" style="margin-bottom:0;">
        </div>
      </div>
    </div>`).join('');
}

function calcProporzioniStoriche(dal, al){
  const rStor = reports.filter(x=>(!dal||x.data>=dal)&&(!al||x.data<=al));
  let orgUscita=0, ammTot=0, inoRiut=0, vagl=0, sovvProd=0, sovvFossa=0, sovvCamion=0, nCamion=0;

  rStor.forEach(rep=>{
    (rep.materiali||[]).forEach(m=>{
      const nl=(m.nome||'').toLowerCase();
      const da=(m.da||'').trim();
      const a=(m.a||'').trim();
      const daL=da.toLowerCase();
      if(nl.includes('organico')&&!da) orgUscita+=(m.peso||0);
      if(nl.includes('vagliatura')) vagl+=(m.peso||0);
      if(nl.includes('sovvallo')){
        if(daL.includes('50x50')) sovvFossa+=(m.peso||0);
        else sovvProd+=(m.peso||0);
      }
      if(nl.includes('inoculo')&&a) inoRiut+=(m.peso||0);
    });
    ammTot += (rep.ammendante?.qta||0);
    (rep.camion?.carichi||[]).forEach(c=>{
      if((c.nome||'').toLowerCase().includes('sovvallo')){
        sovvCamion+=(c.peso||0);
        nCamion+=(c.numCamion||0);
      }
    });
  });

  const inoculoProd = Math.max(0, vagl - sovvProd);
  const totSovvUscita = sovvFossa + sovvCamion;

  // Proporzioni su organico lavorato (uscita)
  const pAmm  = orgUscita > 0 ? ammTot     / orgUscita : 0;
  const pIno  = orgUscita > 0 ? inoculoProd / orgUscita : 0;
  const pSovv = orgUscita > 0 ? sovvProd    / orgUscita : 0;
  // Camion per tonnellata di sovvallo
  const camPerTon = sovvCamion > 0 ? nCamion / (sovvCamion/1000) : 0;

  return { pAmm, pIno, pSovv, camPerTon, orgUscita, ammTot, inoculoProd, sovvProd, totSovvUscita, nCamion };
}

function renderMultiFase(){
  const dal = document.getElementById('mfStoricoDal')?.value||'';
  const al  = document.getElementById('mfStoricoAl')?.value||'';
  const camDisp = parseFloat(document.getElementById('mfCamionDisp')?.value)||0;
  const pr  = document.getElementById('mfRisultati');
  const infoEl = document.getElementById('mfProporzioniInfo');

  if(!dal || !al){ 
    if(infoEl) infoEl.textContent = 'Seleziona il periodo storico per calcolare le proporzioni.';
    if(pr) pr.innerHTML = '';
    return; 
  }

  const prop = calcProporzioniStoriche(dal, al);
  if(infoEl) infoEl.innerHTML = 
    `Proporzioni calcolate dal ${fmtDataShort(dal)} al ${fmtDataShort(al)}: ` +
    `Ammendante <strong>${(prop.pAmm*100).toFixed(1)}%</strong> · ` +
    `Inoculo <strong>${(prop.pIno*100).toFixed(1)}%</strong> · ` +
    `Sovvallo <strong>${(prop.pSovv*100).toFixed(1)}%</strong> · ` +
    `${prop.camPerTon.toFixed(2)} cam/t sovvallo`;

  // Depositi iniziali dai depositi correnti
  const { r, c } = getDepFiltered();
  const dep = calcDepositi(r, c);

  let depOrg  = dep.organico;
  let depIno  = dep.inoculo;
  let depSovv = dep.sovvallo;

  const now = new Date();
  let dataCorrente = new Date(now);
  let fasiHTML = '';
  let totaleAmm=0, totaleIno=0, totaleSovv=0, totaleCamionExtra=0;

  mfFasi.forEach((f, i) => {
    const sett = f.settimane || 1;
    const ingrSett  = f.ingresso ? parseFloat(f.ingresso)*1000 : 0;
    const uscitaSett = f.uscita  ? parseFloat(f.uscita)*1000  : 0;

    // Prodotti generati dall'uscita organico
    const ammSett  = uscitaSett * prop.pAmm;
    const inoSett  = uscitaSett * prop.pIno;
    const sovvSett = uscitaSett * prop.pSovv;

    // Camion necessari vs disponibili per sovvallo
    const camNec  = sovvSett/1000 * prop.camPerTon * sett;
    const camTot  = camDisp * sett;
    const camExtra = Math.max(0, camNec - camTot);

    // Variazione depositi nella fase
    const deltaOrg  = (ingrSett - uscitaSett) * sett;
    const deltaIno  = inoSett * sett;       // inoculo prodotto va a deposito
    const deltaSovv = sovvSett * sett;      // sovvallo prodotto va a deposito

    const depOrgFine  = Math.max(0, depOrg  + deltaOrg);
    const depInoFine  = Math.max(0, depIno  + deltaIno);
    const depSovvFine = Math.max(0, depSovv + deltaSovv);

    const dataFine = new Date(dataCorrente);
    dataFine.setDate(dataCorrente.getDate() + sett*7);
    const dataFineStr = dataFine.toLocaleDateString('it-IT',{day:'2-digit',month:'long',year:'numeric'});

    totaleAmm   += ammSett * sett;
    totaleIno   += inoSett * sett;
    totaleSovv  += sovvSett * sett;
    totaleCamionExtra += camExtra;

    const colore = i%2===0 ? 'var(--accent)' : 'var(--accent3)';

    fasiHTML += `
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--r);padding:14px;margin-bottom:10px;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
          <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:14px;color:${colore};">Fase ${i+1} — ${sett} settimane</div>
          <div style="font-size:11px;color:var(--text-dim);">fino al ${dataFineStr}</div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:10px;">
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:10px;">
            <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;">Organico ingresso</div>
            <div style="font-size:14px;font-weight:700;color:#ffb347;">${fmtPeso(ingrSett*sett)}</div>
            <div style="font-size:10px;color:var(--text-muted);">${fmtPeso(ingrSett)}/sett</div>
          </div>
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:10px;">
            <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;">Organico lavorato</div>
            <div style="font-size:14px;font-weight:700;color:var(--accent3);">${fmtPeso(uscitaSett*sett)}</div>
            <div style="font-size:10px;color:var(--text-muted);">${fmtPeso(uscitaSett)}/sett</div>
          </div>
          <div style="background:var(--surface);border:1px solid ${deltaOrg<=0?'#47ff8a40':'#ff6b3540'};border-radius:var(--rs);padding:10px;">
            <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;">Deposito organico</div>
            <div style="font-size:14px;font-weight:700;color:${deltaOrg<=0?'var(--success)':'var(--accent2)'};">${fmtPeso(depOrgFine)}</div>
            <div style="font-size:10px;color:var(--text-muted);">${deltaOrg<=0?'▼ '+fmtPeso(Math.abs(deltaOrg)):' ▲ '+fmtPeso(deltaOrg)}</div>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;">
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:10px;">
            <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;">Ammendante prodotto</div>
            <div style="font-size:14px;font-weight:700;color:var(--success);">${fmtPeso(ammSett*sett)}</div>
            <div style="font-size:10px;color:var(--text-muted);">${fmtPeso(ammSett)}/sett</div>
          </div>
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:10px;">
            <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;">Inoculo prodotto → dep.</div>
            <div style="font-size:14px;font-weight:700;color:#ffb347;">${fmtPeso(inoSett*sett)}</div>
            <div style="font-size:10px;color:var(--text-dim);">Deposito: ${fmtPeso(depInoFine)}</div>
          </div>
          <div style="background:var(--surface);border:1px solid ${camExtra>0?'#ff6b3540':'var(--border)'};border-radius:var(--rs);padding:10px;">
            <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;">Sovvallo → camion</div>
            <div style="font-size:14px;font-weight:700;color:${camExtra>0?'var(--accent2)':'var(--success)'};">${Math.round(camNec)} cam</div>
            <div style="font-size:10px;color:${camExtra>0?'var(--accent2)':'var(--text-muted)'};">
              ${camDisp>0?(camExtra>0?'⚠ +'+Math.round(camExtra)+' extra vs '+camTot+' disp.':'✓ '+Math.round(camNec)+'/'+camTot+' disp.'):'imp. camion/sett'}
            </div>
          </div>
        </div>
      </div>`;

    // Aggiorna depositi per fase successiva
    depOrg  = depOrgFine;
    depIno  = depInoFine;
    depSovv = depSovvFine;
    dataCorrente = dataFine;
  });

  // Riepilogo finale
  const totSett = mfFasi.reduce((s,f)=>s+(f.settimane||1),0);
  const dataFinaleTot = new Date(now); dataFinaleTot.setDate(now.getDate()+totSett*7);

  fasiHTML += `
    <div style="background:var(--surface);border:2px solid var(--accent);border-radius:var(--r);padding:14px;margin-top:4px;">
      <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:14px;color:var(--accent);margin-bottom:12px;">
        📊 Riepilogo finale — ${totSett} settimane totali
      </div>
      <div style="font-size:12px;color:var(--text-dim);margin-bottom:10px;">
        Situazione al ${dataFinaleTot.toLocaleDateString('it-IT',{day:'2-digit',month:'long',year:'numeric'})}
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;">
        <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:10px;">
          <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;">Deposito organico finale</div>
          <div style="font-size:16px;font-weight:800;color:var(--accent);">${fmtPeso(depOrg)}</div>
        </div>
        <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:10px;">
          <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;">Deposito inoculo finale</div>
          <div style="font-size:16px;font-weight:800;color:#ffb347;">${fmtPeso(depIno)}</div>
        </div>
        <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:10px;">
          <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;">Deposito sovvallo finale</div>
          <div style="font-size:16px;font-weight:800;color:var(--accent3);">${fmtPeso(depSovv)}</div>
        </div>
        <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:10px;">
          <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;">Ammendante totale</div>
          <div style="font-size:16px;font-weight:800;color:var(--success);">${fmtPeso(totaleAmm)}</div>
        </div>
        <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:10px;">
          <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;">Inoculo totale prodotto</div>
          <div style="font-size:16px;font-weight:800;color:#ffb347;">${fmtPeso(totaleIno)}</div>
        </div>
        <div style="background:var(--surface2);border:1px solid ${totaleCamionExtra>0?'#ff6b3540':'var(--border)'};border-radius:var(--rs);padding:10px;">
          <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;">Camion extra necessari</div>
          <div style="font-size:16px;font-weight:800;color:${totaleCamionExtra>0?'var(--accent2)':'var(--success)'};">${Math.round(totaleCamionExtra)}</div>
          <div style="font-size:10px;color:var(--text-muted);">${totaleCamionExtra>0?'oltre quelli disponibili':'nessun extra'}</div>
        </div>
      </div>
    </div>`;

  if(pr) pr.innerHTML = fasiHTML;
}

// Init multi-fase on page load
function initMultiFase(){
  renderFasiInput();
  const now = new Date();
  const tre = new Date(now); tre.setMonth(now.getMonth()-3);
  const el1 = document.getElementById('mfStoricoDal');
  const el2 = document.getElementById('mfStoricoAl');
  if(el1) el1.value = tre.toISOString().split('T')[0];
  if(el2) el2.value = now.toISOString().split('T')[0];
}

