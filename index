function delEmail(i){
  if(!confirm('Rimuovere "'+settings.emails[i]+'"?')) return;
  settings.emails.splice(i,1); saveSettings();
  renderEmailList();
  syncEmailConfig();
}

function syncEmailConfig(){
  // Salva la configurazione email sullo script Drive
  const scriptUrl = localStorage.getItem('pl_script_url') || '';
  if(!scriptUrl || !settings.emails.length) return;
  fetch(scriptUrl, {
    method: 'POST', mode: 'no-cors',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      action: 'saveConfig',
      filename: 'pesolog_config.json',
      json: JSON.stringify({ emails: settings.emails })
    })
  }).catch(()=>{});
}

