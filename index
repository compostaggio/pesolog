function ripristinaDaDrive(){
  const input = document.createElement('input');
  input.type = 'file'; input.accept = '.json';
  input.onchange = (e) => {
    const file = e.target.files[0];
    if(!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
      try {
        let data = JSON.parse(ev.target.result.trim());
        if(!Array.isArray(data)){
          if(data.reports && Array.isArray(data.reports)) data = data.reports;
          else throw new Error('Formato non valido');
        }
        data = data.filter(r => r && r.id && r.data);
        data.forEach(r => { r.materiali = r.materiali || []; });
        const existing = new Set(reports.map(r=>String(r.id)));
        let nuovi = 0;
        data.forEach(r => { if(!existing.has(String(r.id))){ reports.push(r); nuovi++; } });
        reports.sort((a,b)=>new Date(a.data)-new Date(b.data));
        saveData();
        renderStorico();
        renderRiepilogo();
        showToast('✓ ' + (nuovi>0 ? nuovi+' report ripristinati' : 'Già aggiornati'), 'var(--success)');
        document.getElementById('driveHint').textContent = '✓ Ripristino completato: '+data.length+' report totali';
        document.getElementById('driveHint').style.color = 'var(--success)';
      } catch(err){
        showToast('⚠ Errore: ' + err.message,'#ff6b35');
        console.error('Errore ripristina:', err);
      }
    };
    reader.readAsText(file);
  };
  input.click();
}


