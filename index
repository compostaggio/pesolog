function buildCSV(){
  const rows=[['Data','Operatore','Turno','Tipo','Materiale/Carico','Da','A','Peso kg','N° Camion','Box Ammendante','Qty Ammendante kg','Totale kg','Note']];
  reports.forEach(r=>{
    const matRows=r.materiali.map(m=>['materiale',m.nome,m.da||'',m.a||'',m.peso,'','']);
    const camRows=(r.camion?.carichi||[]).map(c=>['camion',c.nome,'','',c.peso,c.numCamion,'']);
    const ammRow=r.ammendante?[['ammendante','','',r.ammendante.box,r.ammendante.qta,'',r.ammendante.qta]]:[];
    const all=[...matRows,...camRows,...ammRow];
    if(!all.length) all.push(['','','','','','','']);
    all.forEach((row,i)=>{
      rows.push([r.data,i===0?r.operatore:'',i===0?r.turno:'',
