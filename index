// Calcola la quota proporzionale di un conferimento che cade in un periodo
function quotaConferimento(x, periDal, periAl){
  if(!periDal || !periAl) return x.qta;
  const inizio = new Date(Math.max(new Date(x.dal+'T12:00:00'), new Date(periDal+'T12:00:00')));
  const fine   = new Date(Math.min(new Date(x.al+'T12:00:00'),  new Date(periAl+'T12:00:00')));
  const giorniTot     = (new Date(x.al+'T12:00:00') - new Date(x.dal+'T12:00:00')) / (24*3600*1000) + 1;
  const giorniOverlap = Math.max(0, (fine - inizio) / (24*3600*1000) + 1);
  return x.qta * (giorniOverlap / giorniTot);
}

function settimaneTraDate(dal, al){
  if(!dal || !al) return 1;
  // Calcola settimane esatte basandosi sui giorni — funziona con qualsiasi periodo (settimanale, mensile, ecc.)
  const giorni = (new Date(al+'T12:00:00') - new Date(dal+'T12:00:00')) / (24*3600*1000) + 1;
  return Math.max(0.14, giorni / 7); // minimo 1 giorno
}

function renderPrevisione(){
  const mat    = document.getElementById('prevMateriale')?.value||'organico';
  const lavDal = document.getElementById('prevLavDal')?.value||'';
  const lavAl  = document.getElementById('prevLavAl')?.value||'';
  const confDal= document.getElementById('prevConfDal')?.value||'';
  const confAl = document.getElementById('prevConfAl')?.value||'';
  const now    = new Date();

  // Deposito attuale
  const { r, c } = getDepFiltered();
  const dep = calcDepositi(r, c);

  // Report nel periodo lavorato
  const rLav = reports.filter(x=>(!lavDal||x.data>=lavDal)&&(!lavAl||x.data<=lavAl));
  // Conferimenti nel periodo conferimento
  // Calcola quota proporzionale di ogni conferimento che cade nel periodo selezionato
  const cConf = conferimenti.filter(x=>(!confDal||x.al>=confDal)&&(!confAl||x.dal<=confAl));

  const nSettLav  = settimaneTraDate(lavDal, lavAl);
  const nSettConf = settimaneTraDate(confDal, confAl);

  let uscitaTot=0, ingressoTot=0;

  if(mat==='sovvallo'){
    let sfossa=0, scamion=0, sprod=0;
    rLav.forEach(rep=>{
      (rep.materiali||[]).forEach(m=>{
        const nl=(m.nome||'').toLowerCase();
        const daL=(m.da||'').toLowerCase();
        if(nl.includes('sovvallo')){
          if(daL.includes('50x50')) sfossa+=(m.peso||0);
          else sprod+=(m.peso||0);
        }
      });
      (rep.camion?.carichi||[]).forEach(c=>{
        if((c.nome||'').toLowerCase().includes('sovvallo')) scamion+=(c.peso||0);
      });
    });
    uscitaTot   = sfossa + scamion;
    ingressoTot = sprod;

  } else if(mat==='inoculo'){
    let vagl=0, sprod=0, iriut=0;
    rLav.forEach(rep=>{
      (rep.materiali||[]).forEach(m=>{
        const nl=(m.nome||'').toLowerCase();
        const a=(m.a||'').trim();
        const daL=(m.da||'').toLowerCase();
        if(nl.includes('vagliatura')) vagl+=(m.peso||0);
        else if(nl.includes('sovvallo')&&!daL.includes('50x50')) sprod+=(m.peso||0);
        else if(nl.includes('inoculo')&&a) iriut+=(m.peso||0);
      });
    });
    ingressoTot = Math.max(0, vagl - sprod);
    uscitaTot   = iriut;

  } else { // organico
    rLav.forEach(rep=>{
      (rep.materiali||[]).forEach(m=>{
        const nl=(m.nome||'').toLowerCase();
        const da=(m.da||'').trim();
        if(nl.includes('organico')&&!da) uscitaTot+=(m.peso||0);
      });
    });
    ingressoTot = cConf.reduce((s,x)=>s+quotaConferimento(x,confDal,confAl),0);
  }

  const uscitaSett   = uscitaTot  / nSettLav;
  const ingressoSett = ingressoTot / (mat==='organico' ? nSettConf : nSettLav);

  // Deposito attuale
  let depositoAttuale=0;
  if(mat==='sovvallo')     depositoAttuale = dep.sovvallo;
  else if(mat==='inoculo') depositoAttuale = dep.inoculo;
  else                     depositoAttuale = dep.organico;

  const nettaSett = uscitaSett - ingressoSett; // positivo = smaltimento netto

  const pr = document.getElementById('previsioneResult');

  if(depositoAttuale <= 0){
    pr.innerHTML = '<div style="color:var(--success);font-size:13px;padding:12px 0;">✓ Nessun deposito da smaltire.</div>';
    return;
  }
  if(nettaSett <= 0){
    pr.innerHTML = `<div style="color:var(--accent2);font-size:13px;padding:12px 0;">
      ⚠ Il deposito sta crescendo — l'ingresso (${fmtPeso(ingressoSett)}/sett) supera l'uscita (${fmtPeso(uscitaSett)}/sett).
    </div>`;
    return;
  }

  const settimane = Math.ceil(depositoAttuale / nettaSett);
  const dataSmaltimento = new Date(now);
  dataSmaltimento.setDate(now.getDate() + settimane*7);

  pr.innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;">
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:12px;">
        <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Deposito attuale</div>
        <div style="font-size:18px;font-weight:800;color:var(--accent);">${fmtPeso(depositoAttuale)}</div>
      </div>
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:12px;">
        <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Smaltimento netto/sett</div>
        <div style="font-size:18px;font-weight:800;color:var(--success);">${fmtPeso(nettaSett)}</div>
      </div>
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:12px;">
        <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Ingresso medio/sett</div>
        <div style="font-size:16px;font-weight:700;color:#ffb347;">${fmtPeso(ingressoSett)}</div>
      </div>
      <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:12px;">
        <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Uscita media/sett</div>
        <div style="font-size:16px;font-weight:700;color:var(--accent3);">${fmtPeso(uscitaSett)}</div>
      </div>
    </div>
    <div style="background:var(--surface2);border:1px solid var(--accent);border-radius:var(--rs);padding:14px;text-align:center;">
      <div style="font-size:11px;color:var(--text-dim);margin-bottom:6px;">Stima smaltimento completo</div>
      <div style="font-size:22px;font-weight:800;color:var(--accent);">${settimane} settimane</div>
      <div style="font-size:12px;color:var(--text-dim);margin-top:4px;">
        entro ${dataSmaltimento.toLocaleDateString('it-IT',{day:'2-digit',month:'long',year:'numeric'})}
      </div>
    </div>
    <div style="font-size:10px;color:var(--text-muted);margin-top:8px;text-align:center;">
      Lavorato: ${nSettLav} sett. · Conferito: ${nSettConf} sett.
    </div>`;
  renderObiettivoSuggestion();
  renderSimulatore();
}

