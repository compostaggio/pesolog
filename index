function ripristinaConferimenti(){
  const input = document.createElement('input');
  input.type = 'file'; input.accept = '.json';
  input.onchange = (e) => {
    const file = e.target.files[0];
    if(!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
      try {
        const data = JSON.parse(ev.target.result);
        if(!Array.isArray(data)) throw new Error('Formato non valido');
        const existing = new Set(conferimenti.map(c=>String(c.id)));
        let nuovi = 0;
        data.forEach(c => { if(!existing.has(String(c.id))){ conferimenti.push(c); nuovi++; } });
        conferimenti.sort((a,b)=>a.data.localeCompare(b.data));
        saveConferimenti();
        renderDepositi();
        showToast('✓ ' + (nuovi>0 ? nuovi+' conferimenti ripristinati' : 'Già aggiornati'), 'var(--success)');
      } catch(err) { showToast('⚠ File non valido','#ff6b35'); }
    };
    reader.readAsText(file);
  };
  input.click();
}

function unisciDaAltroDispositivo(){
  const input = document.createElement('input');
  input.type = 'file'; input.accept = '.json';
  input.onchange = (e) => {
    const file = e.target.files[0];
    if(!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
      try {
        let data = JSON.parse(ev.target.result.trim());
        if(!Array.isArray(data)){
          if(data.reports && Array.isArray(data.reports)) data = data.reports;
          else throw new Error('Formato non valido');
        }
        data = data.filter(r => r && r.id && r.data);
        data.forEach(r => { r.materiali = r.materiali || []; });
        const existing = new Set(reports.map(r=>String(r.id)));
        let nuovi = 0;
        data.forEach(r => {
          if(!existing.has(String(r.id))){ reports.push(r); nuovi++; }
          else {
            const idx = reports.findIndex(x=>String(x.id)===String(r.id));
            if(idx>=0 && (r.ts||'')>=(reports[idx].ts||'')) reports[idx] = r;
          }
        });
        reports.sort((a,b)=>new Date(a.data)-new Date(b.data));
        saveData();
        renderStorico();
        renderRiepilogo();
        showToast('✓ ' + nuovi + ' nuovi report aggiunti', 'var(--success)');
        document.getElementById('driveHint').textContent = '✓ Completato: ' + reports.length + ' report totali';
        document.getElementById('driveHint').style.color = 'var(--success)';
      } catch(err){
        showToast('⚠ Errore: ' + err.message,'#ff6b35');
        console.error('Errore unisci:', err);
      }
    };
    reader.readAsText(file);
  };
  input.click();
}

