function stampaDigestori(){
  const da  = document.getElementById('filterDa').value;
  const a   = document.getElementById('filterA').value;
  const f   = getFiltered();

  if(!f.length){ showToast('⚠ Nessun dato nel periodo','#ff6b35'); return; }

  // Raccogli tutti i carichi organico → digestore, raggruppati per digestore
  // Struttura: { 'Dige1': [ {data, kg}, ... ], ... }
  const digeCarichi = {};
  f.forEach(r => r.materiali.forEach(m => {
    const nl = m.nome.toLowerCase();
    const aVal = (m.a||'').toLowerCase();
    if(nl.includes('organico') && aVal.includes('dige')){
      const dige = (m.a||'').trim();
      if(!digeCarichi[dige]) digeCarichi[dige] = [];
      digeCarichi[dige].push({ data: r.data, kg: m.peso||0 });
    }
  }));

  if(!Object.keys(digeCarichi).length){
    showToast('⚠ Nessun carico digestore nel periodo','#ff6b35');
    return;
  }

  // Per ogni digestore, raggruppa in cicli (gap > 7 giorni = nuovo ciclo)
  // Ogni ciclo: { dataFine, totKg }
  const GAP_GIORNI = 7;
  const cicli = []; // [{dige, dataFine, totKg}]

  Object.entries(digeCarichi).forEach(([dige, carichi]) => {
    // Ordina per data
    carichi.sort((a,b) => a.data.localeCompare(b.data));

    let cicloKg = 0;
    let ultimaData = null;
    let dataFineCiclo = null;

    carichi.forEach((c, i) => {
      if(ultimaData === null){
        // Primo carico
        cicloKg = c.kg;
        ultimaData = c.data;
        dataFineCiclo = c.data;
      } else {
        const diffGiorni = (new Date(c.data) - new Date(ultimaData)) / 86400000;
        if(diffGiorni > GAP_GIORNI){
          // Nuovo ciclo — salva quello precedente
          cicli.push({ dige, dataFine: dataFineCiclo, totKg: cicloKg });
          cicloKg = c.kg;
          dataFineCiclo = c.data;
        } else {
          // Stesso ciclo
          cicloKg += c.kg;
          dataFineCiclo = c.data; // aggiorna data fine
        }
        ultimaData = c.data;
      }
      // Ultimo elemento: salva ciclo corrente
      if(i === carichi.length - 1){
        cicli.push({ dige, dataFine: dataFineCiclo, totKg: cicloKg });
      }
    });
  });

  // Ordina per data fine ciclo, poi per digestore
  cicli.sort((a,b) => a.dataFine.localeCompare(b.dataFine) || a.dige.localeCompare(b.dige));

  const totale = cicli.reduce((s,c) => s + c.totKg, 0);
  const periodoStr = da&&a ? `${da} — ${a}` : da ? `Dal ${da}` : a ? `Fino al ${a}` : 'Tutto il periodo';
  const now = new Date().toLocaleDateString('it-IT',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});

  const righe = cicli.map((c, i) => `
    <tr style="background:${i%2===0?'#f9f9f9':'#fff'}">
      <td style="padding:10px 12px;border:1px solid #ddd;font-weight:600;">
        ${new Date(c.dataFine+'T12:00:00').toLocaleDateString('it-IT',{day:'2-digit',month:'2-digit',year:'numeric'})}
      </td>
      <td style="padding:10px 12px;border:1px solid #ddd;font-weight:700;">${c.dige}</td>
      <td style="padding:10px 12px;border:1px solid #ddd;text-align:right;font-weight:700;">${fmtPeso(c.totKg)}</td>
      <td style="padding:10px 12px;border:1px solid #ddd;text-align:right;color:#666;">${totale>0?(c.totKg/totale*100).toFixed(1)+'%':'-'}</td>
    </tr>`).join('');

  document.getElementById('printArea').innerHTML = `
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px;border-bottom:2px solid #000;padding-bottom:12px;">
      <div>
        <div style="font-size:22px;font-weight:800;letter-spacing:-1px;">PESO<span style="color:#666">LOG</span></div>
        <div style="font-size:14px;font-weight:700;margin-top:4px;color:#333;">Report Carico Digestori</div>
      </div>
      <div style="text-align:right;font-size:12px;color:#666;">
        <div><strong>Periodo:</strong> ${periodoStr}</div>
        <div>Stampato: ${now}</div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:24px;">
      <div style="border:1px solid #ddd;border-radius:8px;padding:12px;">
        <div style="font-size:10px;color:#888;text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Totale caricato</div>
        <div style="font-size:20px;font-weight:800;">${fmtPeso(totale)}</div>
      </div>
      <div style="border:1px solid #ddd;border-radius:8px;padding:12px;">
        <div style="font-size:10px;color:#888;text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Cicli di carico</div>
        <div style="font-size:20px;font-weight:800;">${cicli.length}</div>
      </div>
      <div style="border:1px solid #ddd;border-radius:8px;padding:12px;">
        <div style="font-size:10px;color:#888;text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Digestori coinvolti</div>
        <div style="font-size:20px;font-weight:800;">${new Set(cicli.map(c=>c.dige)).size}</div>
      </div>
    </div>

    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <thead>
        <tr style="background:#1a1a1a;color:#fff;">
          <th style="padding:10px 12px;text-align:left;border:1px solid #333;">Data fine carico</th>
          <th style="padding:10px 12px;text-align:left;border:1px solid #333;">Digestore</th>
          <th style="padding:10px 12px;text-align:right;border:1px solid #333;">Quantità totale</th>
          <th style="padding:10px 12px;text-align:right;border:1px solid #333;">% sul totale</th>
        </tr>
      </thead>
      <tbody>${righe}</tbody>
      <tfoot>
        <tr style="background:#f0f0f0;font-weight:700;">
          <td style="padding:10px 12px;border:1px solid #ddd;" colspan="2">TOTALE</td>
          <td style="padding:10px 12px;border:1px solid #ddd;text-align:right;">${fmtPeso(totale)}</td>
          <td style="padding:10px 12px;border:1px solid #ddd;text-align:right;">100%</td>
        </tr>
      </tfoot>
    </table>
    <div style="margin-top:12px;font-size:11px;color:#888;">
      * I cicli sono calcolati automaticamente: carichi dello stesso digestore con meno di 7 giorni di distanza vengono considerati parte dello stesso ciclo di carico.
    </div>
  `;

  window.print();
}

