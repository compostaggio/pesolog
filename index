function getDriveFilename(){ return 'pesolog_dati.json'; }
function getDriveCSVFilename(){ return 'pesolog_dati.csv'; }
function getDriveConfFilename(){ return 'pesolog_conf.json'; }

async function syncToDrive(silent=false){
  const scriptUrl = localStorage.getItem('pl_script_url') || '';
  if(!scriptUrl) return;

  const btn = document.getElementById('gdriveBtn');
  if(!silent){
    btn.disabled = true; btn.classList.add('loading');
    btn.textContent = 'Salvataggio...';
  }
  const resetBtn = () => {
    btn.disabled = false; btn.classList.remove('loading');
    btn.innerHTML = `<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg> Salva su Google Drive`;
  };
  const safetyTimeout = setTimeout(() => {
    resetBtn();
    if(!silent){
      document.getElementById('driveHint').textContent = '⚠ Timeout — verifica lo Script URL';
      document.getElementById('driveHint').style.color = 'var(--accent2)';
    }
  }, 20000);

  try {
    // Salva JSON reports (merge lato script)
    await fetch(scriptUrl, {
      method: 'POST', mode: 'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action: 'merge',
        filename: getDriveFilename(),
        json: JSON.stringify(reports),
        dispositivo: settings.dispositivo||'pc'
      })
    });
    // Salva CSV aggiornato
    await fetch(scriptUrl, {
      method: 'POST', mode: 'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ filename: getDriveCSVFilename(), json: buildCSV() })
    });
    // Salva conferimenti (merge)
    await fetch(scriptUrl, {
      method: 'POST', mode: 'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action: 'merge',
        filename: getDriveConfFilename(),
        json: JSON.stringify(conferimenti),
        dispositivo: settings.dispositivo||'pc'
      })
    });
    clearTimeout(safetyTimeout);
    if(!silent){
      resetBtn();
      document.getElementById('driveHint').textContent = '✓ Dati salvati in Drive > PesoLog (' + reports.length + ' report)';
      document.getElementById('driveHint').style.color = 'var(--success)';
      showToast('✓ Salvato su Google Drive!', 'var(--success)');
    }
  } catch(e) {
    clearTimeout(safetyTimeout);
    if(!silent){
      resetBtn();
      document.getElementById('driveHint').textContent = '⚠ ' + (e.message||'Errore. Riprova.');
      document.getElementById('driveHint').style.color = 'var(--accent2)';
    }
  }
}

