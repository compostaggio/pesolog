  // We use XMLSerializer to get the actual current DOM
  const fullSrc = '<!DOCTYPE html>\n' + document.documentElement.outerHTML;

  // The settings object in the source uses a known pattern — replace it
  // by injecting current settings as the fallback default
  const settingsJson = JSON.stringify(settings);
  const result = fullSrc.replace(
