  if(!dal || !al || qta<=0){ showToast('⚠ Inserisci dal, al e quantità','#ff6b35'); return; }
  if(dal > al){ showToast('⚠ La data "dal" deve essere prima di "al"','#ff6b35'); return; }
  conferimenti.push({ id: Date.now(), dal, al, qta });
  conferimenti.sort((a,b)=>a.dal.localeCompare(b.dal));
  saveConferimenti();
  syncToDrive(true);
  document.getElementById('confDal').value='';
  document.getElementById('confAl').value='';
  document.getElementById('confQta').value='';
  renderDepositi();
  showToast('✓ Conferimento aggiunto');
}

function delConferimento(id){
  if(!confirm('Eliminare questo conferimento?')) return;
  conferimenti = conferimenti.filter(c=>String(c.id)!==String(id));
  saveConferimenti();
  syncToDrive(true);
  renderDepositi();
}

function getDepFiltered(){
  const da = document.getElementById('depDa')?.value||'';
  const a  = document.getElementById('depA')?.value||'';
  const r  = reports.filter(x=>{ if(da&&x.data<da)return false; if(a&&x.data>a)return false; return true; });
  const c  = conferimenti.filter(x=>{
    if(da && x.al < da) return false;
    if(a  && x.dal > a) return false;
    return true;
  });
  return { r, c };
}

function calcDepositi(r, c){
  let sovvalloProd=0, sovvalloFossa=0, sovvalloCamion=0;
  let inoculoProd=0, inoculoRiut=0;
  let orgLavorato=0, vagliatura=0;

  r.forEach(rep=>{
    (rep.materiali||[]).forEach(m=>{
      const nl=(m.nome||'').toLowerCase();
      const da=(m.da||'').trim();
      const a=(m.a||'').trim();
      const daL=da.toLowerCase();

      if(nl.includes('sovvallo')){
        if(daL.includes('50x50')) sovvalloFossa+=(m.peso||0);
        else sovvalloProd+=(m.peso||0);
      } else if(nl.includes('vagliatura')){
        vagliatura+=(m.peso||0);
      } else if(nl.includes('inoculo')){
        if(a) inoculoRiut+=(m.peso||0);
      } else if(nl.includes('organico')){
        if(!da) orgLavorato+=(m.peso||0);
      }
    });
    // Carico camion sovvallo
    (rep.camion?.carichi||[]).forEach(c=>{
      if((c.nome||'').toLowerCase().includes('sovvallo')) sovvalloCamion+=(c.peso||0);
    });
  });

  inoculoProd = Math.max(0, vagliatura - sovvalloProd);
  const confTot = c.reduce((s,x)=>s+x.qta,0); // somma tutti i conferimenti nel periodo

  // Deposito iniziale: viene sempre incluso come base di partenza.
  // I movimenti dei report vengono calcolati SOLO dopo la data del deposito iniziale,
  // così da non sottrarre movimenti precedenti che sono già compresi nel valore iniziale.
  let diSovvallo=0, diInoculo=0, diOrganico=0;
  if(depIniziale.data){
    diSovvallo = depIniziale.sovvallo||0;
    diInoculo  = depIniziale.inoculo||0;
    diOrganico = depIniziale.organico||0;
    // Ricalcola i movimenti solo dal giorno DOPO il deposito iniziale in poi
    // in modo da non sottrarre due volte i movimenti già inclusi nel deposito iniziale
    const afterDate = depIniziale.data;
    sovvalloProd=0; sovvalloFossa=0; sovvalloCamion=0;
    inoculoProd=0; inoculoRiut=0;
    orgLavorato=0; vagliatura=0;
    r.filter(rep=>rep.data > afterDate).forEach(rep=>{
      (rep.materiali||[]).forEach(m=>{
        const nl=(m.nome||'').toLowerCase();
        const da=(m.da||'').trim();
        const a=(m.a||'').trim();
        const daL=da.toLowerCase();
        if(nl.includes('sovvallo')){
          if(daL.includes('50x50')) sovvalloFossa+=(m.peso||0);
          else sovvalloProd+=(m.peso||0);
        } else if(nl.includes('vagliatura')){
          vagliatura+=(m.peso||0);
        } else if(nl.includes('inoculo')){
          if(a) inoculoRiut+=(m.peso||0);
        } else if(nl.includes('organico')){
          if(!da) orgLavorato+=(m.peso||0);
        }
      });
      (rep.camion?.carichi||[]).forEach(c=>{
        if((c.nome||'').toLowerCase().includes('sovvallo')) sovvalloCamion+=(c.peso||0);
      });
    });
    inoculoProd = Math.max(0, vagliatura - sovvalloProd);
    // Conferimenti solo dopo la data deposito iniziale
    const confDopoIniziale = c.filter(x=>x.dal > afterDate);
    const confTotDopoIniziale = confDopoIniziale.reduce((s,x)=>s+x.qta,0);
    return {
      sovvallo: Math.max(0, diSovvallo + sovvalloProd - sovvalloFossa - sovvalloCamion),
      inoculo:  Math.max(0, diInoculo  + inoculoProd  - inoculoRiut),
      organico: Math.max(0, diOrganico + confTotDopoIniziale - orgLavorato),
      sovvalloProd, sovvalloFossa, sovvalloCamion,
      inoculoProd, inoculoRiut,
      orgLavorato, confTot: confTotDopoIniziale, vagliatura,
      diSovvallo, diInoculo, diOrganico
    };
  }

  return {
    sovvallo: Math.max(0, sovvalloProd - sovvalloFossa - sovvalloCamion),
    inoculo:  Math.max(0, inoculoProd  - inoculoRiut),
    organico: Math.max(0, confTot      - orgLavorato),
    sovvalloProd, sovvalloFossa, sovvalloCamion,
    inoculoProd, inoculoRiut,
    orgLavorato, confTot, vagliatura,
    diSovvallo:0, diInoculo:0, diOrganico:0
  };
}

