// ── SIMULATORE ───────────────────────────────────────────────────────────
function renderSimulatore(){
  const mat        = document.getElementById('prevMateriale')?.value||'organico';
  const dataObj    = document.getElementById('prevObiettivoData')?.value||'';
  const simIngStr  = document.getElementById('simIngresso')?.value;
  const simUscStr  = document.getElementById('simUscita')?.value;
  const pr         = document.getElementById('simulatoreResult');

  // Deposito attuale
  const { r, c } = getDepFiltered();
  const dep = calcDepositi(r, c);
  let depositoAttuale=0;
  if(mat==='sovvallo')     depositoAttuale = dep.sovvallo;
  else if(mat==='inoculo') depositoAttuale = dep.inoculo;
  else                     depositoAttuale = dep.organico;

  if(depositoAttuale <= 0){
    pr.innerHTML='<div style="color:var(--success);font-size:12px;padding:8px 0;">✓ Nessun deposito da smaltire.</div>';
    return;
  }

  // Leggi medie reali dalla previsione
  const lavDal  = document.getElementById('prevLavDal')?.value||'';
  const lavAl   = document.getElementById('prevLavAl')?.value||'';
  const confDal = document.getElementById('prevConfDal')?.value||'';
  const confAl  = document.getElementById('prevConfAl')?.value||'';
  const nSettLav  = settimaneTraDate(lavDal, lavAl);
  const nSettConf = settimaneTraDate(confDal, confAl);

  const rLav  = reports.filter(x=>(!lavDal||x.data>=lavDal)&&(!lavAl||x.data<=lavAl));
  const cConf = conferimenti.filter(x=>(!confDal||x.al>=confDal)&&(!confAl||x.dal<=confAl));

  let uscitaTotReale=0, ingressoTotReale=0;
  if(mat==='sovvallo'){
    let sfossa=0, scamion=0, sprod=0;
    rLav.forEach(rep=>{
      (rep.materiali||[]).forEach(m=>{
        const nl=(m.nome||'').toLowerCase(); const daL=(m.da||'').toLowerCase();
        if(nl.includes('sovvallo')){ if(daL.includes('50x50')) sfossa+=(m.peso||0); else sprod+=(m.peso||0); }
      });
      (rep.camion?.carichi||[]).forEach(c=>{ if((c.nome||'').toLowerCase().includes('sovvallo')) scamion+=(c.peso||0); });
    });
    uscitaTotReale=sfossa+scamion; ingressoTotReale=sprod;
  } else if(mat==='inoculo'){
    let vagl=0, sprod=0, iriut=0;
    rLav.forEach(rep=>{
      (rep.materiali||[]).forEach(m=>{
        const nl=(m.nome||'').toLowerCase(); const a=(m.a||'').trim(); const daL=(m.da||'').toLowerCase();
        if(nl.includes('vagliatura')) vagl+=(m.peso||0);
        else if(nl.includes('sovvallo')&&!daL.includes('50x50')) sprod+=(m.peso||0);
        else if(nl.includes('inoculo')&&a) iriut+=(m.peso||0);
      });
    });
    ingressoTotReale=Math.max(0,vagl-sprod); uscitaTotReale=iriut;
  } else {
    rLav.forEach(rep=>{
      (rep.materiali||[]).forEach(m=>{
        const nl=(m.nome||'').toLowerCase(); const da=(m.da||'').trim();
        if(nl.includes('organico')&&!da) uscitaTotReale+=(m.peso||0);
      });
    });
    ingressoTotReale=cConf.reduce((s,x)=>s+quotaConferimento(x,confDal,confAl),0);
  }

  const uscitaReale   = uscitaTotReale  / nSettLav;
  const ingressoReale = ingressoTotReale / (mat==='organico' ? nSettConf : nSettLav);

  // Usa valori ipoteticci se inseriti, altrimenti reali
  const uscitaSim   = simUscStr   ? parseFloat(simUscStr)*1000   : uscitaReale;
  const ingressoSim = simIngStr   ? parseFloat(simIngStr)*1000   : ingressoReale;
  const nettaSim    = uscitaSim - ingressoSim;

  const now = new Date();
  const matLabel = mat==='sovvallo'?'Sovvallo':mat==='inoculo'?'Inoculo':'Organico';

  // Settimane necessarie con i valori simulati
  let settimaneSimulate = nettaSim > 0 ? Math.ceil(depositoAttuale / nettaSim) : null;
  let dataSimStr = '';
  if(settimaneSimulate){
    const dataSim = new Date(now);
    dataSim.setDate(now.getDate() + settimaneSimulate*7);
    dataSimStr = dataSim.toLocaleDateString('it-IT',{day:'2-digit',month:'long',year:'numeric'});
  }

  // Confronto con scenario reale
  const nettaReale = uscitaReale - ingressoReale;
  const settimaneReali = nettaReale > 0 ? Math.ceil(depositoAttuale / nettaReale) : null;

  const deltaIngresso = ingressoSim - ingressoReale;
  const deltaUscita   = uscitaSim   - uscitaReale;

  const fmtDelta = (v) => {
    const t = v/1000;
    const sign = t>=0 ? '+' : '';
    return sign + t.toFixed(2).replace('.',',') + ' t/sett';
  };

  pr.innerHTML = `
    <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--rs);padding:14px;margin-bottom:10px;">
      <div style="font-size:11px;color:var(--text-dim);margin-bottom:10px;text-align:center;">Scenario ipotetico vs reale — ${matLabel}</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;">
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:10px;">
          <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Ingresso</div>
          <div style="font-size:16px;font-weight:800;color:#ffb347;">${(ingressoSim/1000).toFixed(2).replace('.',',')} t/sett</div>
          ${deltaIngresso!==0?`<div style="font-size:10px;color:${deltaIngresso<0?'var(--success)':'var(--accent2)'};margin-top:2px;">${fmtDelta(deltaIngresso)} vs reale</div>`:''}
        </div>
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:10px;">
          <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Uscita</div>
          <div style="font-size:16px;font-weight:800;color:var(--accent3);">${(uscitaSim/1000).toFixed(2).replace('.',',')} t/sett</div>
          ${deltaUscita!==0?`<div style="font-size:10px;color:${deltaUscita>0?'var(--success)':'var(--accent2)'};margin-top:2px;">${fmtDelta(deltaUscita)} vs reale</div>`:''}
        </div>
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:10px;">
          <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Smaltimento netto</div>
          <div style="font-size:16px;font-weight:800;color:${nettaSim>0?'var(--success)':'var(--accent2)'};">${(nettaSim/1000).toFixed(2).replace('.',',')} t/sett</div>
        </div>
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--rs);padding:10px;">
          <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Deposito attuale</div>
          <div style="font-size:16px;font-weight:800;color:var(--accent);">${(depositoAttuale/1000).toFixed(2).replace('.',',')} t</div>
        </div>
      </div>
      ${nettaSim <= 0
        ? `<div style="background:#1a0f08;border:1px solid var(--accent2);border-radius:var(--rs);padding:12px;text-align:center;color:var(--accent2);font-size:13px;">
            ⚠ Con questi valori il deposito sta crescendo — l'ingresso supera l'uscita.
           </div>`
        : `<div style="background:var(--surface);border:1px solid var(--accent);border-radius:var(--rs);padding:12px;text-align:center;">
            <div style="font-size:11px;color:var(--text-dim);margin-bottom:4px;">Stima smaltimento con scenario ipotetico</div>
            <div style="font-size:22px;font-weight:800;color:var(--accent);">${settimaneSimulate} settimane</div>
            <div style="font-size:12px;color:var(--text-dim);margin-top:4px;">entro ${dataSimStr}</div>
            ${settimaneReali ? `<div style="font-size:11px;color:var(--text-muted);margin-top:6px;">
              Scenario reale: ${settimaneReali} settimane — 
              <span style="color:${settimaneSimulate<settimaneReali?'var(--success)':'var(--accent2)'};">
                ${settimaneSimulate<settimaneReali?'▲ '+( settimaneReali-settimaneSimulate)+' sett. prima':'▼ '+(settimaneSimulate-settimaneReali)+' sett. dopo'}
              </span>
            </div>` : ''}
          </div>`
      }
    </div>`;
}

