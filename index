// ── BACKUP IMPOSTAZIONI ──────────────────────────────────────────────────
function esportaImpostazioni(){
  const backup = {
    version: 1,
    data: new Date().toISOString(),
    settings: settings,
    scriptUrl: localStorage.getItem('pl_script_url') || '',
    depIniziale: depIniziale
  };
  const blob = new Blob([JSON.stringify(backup, null, 2)], {type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'pesolog_impostazioni_' + new Date().toISOString().split('T')[0] + '.json';
  a.click();
  showToast('✓ Impostazioni esportate');
}

function importaImpostazioni(){
  const input = document.createElement('input');
  input.type = 'file'; input.accept = '.json';
  input.onchange = (e) => {
    const file = e.target.files[0];
    if(!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
      try {
        const backup = JSON.parse(ev.target.result.trim());
        if(!backup.settings) throw new Error('File non valido');

        // Ripristina impostazioni
        settings = backup.settings;
        // Assicura chiavi mancanti
        if(!settings.luoghi)    settings.luoghi = ['Magazzino','Area A','Area B','Capannone','Esterno','Banchina'];
        if(!settings.emails)    settings.emails = [];
        if(!settings.dispositivo) settings.dispositivo = 'pc';
        if(!settings.box)       settings.box = [];
        saveSettings();

        // Ripristina script URL
        if(backup.scriptUrl) localStorage.setItem('pl_script_url', backup.scriptUrl);

        // Ripristina deposito iniziale
        if(backup.depIniziale){
          depIniziale = backup.depIniziale;
          saveDepIniziale_();
        }

        // Aggiorna UI
        populateSelects();
        refreshDatalist();
        renderSettingsList('operatori','settingsOperatori');
        renderSettingsList('materiali','settingsMateriali');
        renderSettingsList('box','settingsBox');
        renderSettingsList('luoghi','settingsLuoghi');
        renderEmailList();

        const disp = settings.dispositivo || 'pc';
        document.getElementById('dispositivoStatus').textContent = '✓ Dispositivo: ' + disp;
        document.getElementById('dispositivoStatus').style.color = 'var(--success)';
        if(backup.scriptUrl){
          document.getElementById('clientIdStatus').textContent = '✓ Script URL configurato';
          document.getElementById('clientIdStatus').style.color = 'var(--success)';
        }

        showToast('✓ Impostazioni ripristinate', 'var(--success)');
      } catch(err){
        showToast('⚠ File non valido: ' + err.message, '#ff6b35');
        console.error('Errore importa impostazioni:', err);
      }
    };
    reader.readAsText(file);
  };
  input.click();
}

// ── UTILS ─────────────────────────────────────────────────────────────────
function fmtK(n){ return n>=1000?(n/1000).toFixed(1).replace('.',',')+'k':String(Math.round(n)); }
function fmtPeso(n){ return n>=1000?(n/1000).toFixed(2).replace('.',',')+' t':Math.round(n)+' kg'; }
function fmtData(d){ return new Date(d+'T12:00:00').toLocaleDateString('it-IT',{weekday:'short',day:'numeric',month:'short',year:'numeric'}); }
function fmtDataShort(d){ return new Date(d+'T12:00:00').toLocaleDateString('it-IT',{day:'2-digit',month:'2-digit',year:'2-digit'}); }
